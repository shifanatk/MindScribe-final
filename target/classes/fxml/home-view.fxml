<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane fx:id="mainPane" styleClass="main-border-pane" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mindscribe.HomeController">
    
    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="20">
            <!-- App Logo/Home -->
            <Button fx:id="homeButton" styleClass="sidebar-button, selected" text="🏠" />
            
            <!-- Journal Entries -->
            <Button fx:id="journalButton" styleClass="sidebar-button" text="📝" />
            
            <!-- Analytics -->
            <Button fx:id="analyticsButton" styleClass="sidebar-button" text="📊" />
            
            <!-- AI Insights -->
            <Button fx:id="aiButton" styleClass="sidebar-button" text="🤖" />
            
            <!-- Settings -->
            <Button fx:id="settingsButton" styleClass="sidebar-button" text="⚙️" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <!-- Logout Button -->
            <Button fx:id="logoutButton" styleClass="glass-button" text="🚪 Logout" prefWidth="60" prefHeight="40" />
        </VBox>
    </left>
    
    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="30" alignment="TOP_CENTER" styleClass="glass-container">
            <!-- WELCOME SECTION -->
            <VBox spacing="15" alignment="CENTER">
                <Label fx:id="dateLabel" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #A5B4FC;" />
                <Button fx:id="writeJournalButton" styleClass="glass-button, primary-button" text="✍️ Write New Journal Entry" prefWidth="250" prefHeight="50" />
                <Label text="Welcome back! How are you feeling today?" style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;" />
            </VBox>
            
            <!-- QUICK ACTIONS -->
            <VBox spacing="20" alignment="CENTER">
                <Label text="Quick Actions" style="-fx-font-size: 20px; -fx-font-weight: 600; -fx-text-fill: #E2E8F0;" />
                <HBox spacing="20" alignment="CENTER">
                    <Button fx:id="viewEntriesButton" styleClass="glass-button" text="📚 View Entries" prefWidth="180" prefHeight="45" />
                    <Button fx:id="analyticsButton" styleClass="glass-button" text="📊 Analytics" prefWidth="180" prefHeight="45" />
                    <Button fx:id="aiInsightsButton" styleClass="glass-button" text="🤖 AI Insights" prefWidth="180" prefHeight="45" />
                </HBox>
            </VBox>
            
            <!-- INSPIRATIONAL QUOTE -->
            <VBox spacing="10" alignment="CENTER" styleClass="glass-surface">
                <Label text="💭 Daily Inspiration" style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #A5B4FC;" />
                <Label text="\"The journey of a thousand miles begins with a single step.\"" 
                       style="-fx-font-size: 14px; -fx-text-fill: #E2E8F0; -fx-font-style: italic; -fx-wrap-text: true;" 
                       maxWidth="400" alignment="CENTER" />
                <Label text="- Lao Tzu" style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;" />
            </VBox>
        </VBox>
    </center>
    
</BorderPane>
