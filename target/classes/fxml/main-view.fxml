<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>

<BorderPane fx:id="mainPane" styleClass="main-border-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mindscribe.PureMainController">
    
    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="20">
            <!-- App Logo/Home -->
            <Button fx:id="homeButton" styleClass="sidebar-button, selected">
                <graphic>
                    <ImageView styleClass="sidebar-icon">
                        <Image url="@images/home-icon.png" />
                    </ImageView>
                </graphic>
            </Button>
            
            <!-- Journal Entries -->
            <Button fx:id="journalButton" styleClass="sidebar-button">
                <graphic>
                    <ImageView styleClass="sidebar-icon">
                        <Image url="@images/journal-icon.png" />
                    </ImageView>
                </graphic>
            </Button>
            
            <!-- Analytics -->
            <Button fx:id="analyticsButton" styleClass="sidebar-button">
                <graphic>
                    <ImageView styleClass="sidebar-icon">
                        <Image url="@images/analytics-icon.png" />
                    </ImageView>
                </graphic>
            </Button>
            
            <!-- AI Insights -->
            <Button fx:id="aiButton" styleClass="sidebar-button">
                <graphic>
                    <ImageView styleClass="sidebar-icon">
                        <Image url="@images/ai-icon.png" />
                    </ImageView>
                </graphic>
            </Button>
            
            <!-- Settings -->
            <Button fx:id="settingsButton" styleClass="sidebar-button">
                <graphic>
                    <ImageView styleClass="sidebar-icon">
                        <Image url="@images/settings-icon.png" />
                    </ImageView>
                </graphic>
            </Button>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <!-- User Profile -->
            <Button fx:id="profileButton" styleClass="sidebar-button">
                <graphic>
                    <ImageView styleClass="sidebar-icon">
                        <Image url="@images/profile-icon.png" />
                    </ImageView>
                </graphic>
            </Button>
        </VBox>
    </left>
    
    <!-- CENTER CONTENT -->
    <center>
        <StackPane styleClass="glass-container">
            <VBox spacing="25" styleClass="fade-in">
                <!-- HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label fx:id="dateLabel" styleClass="subtitle-text" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="saveButton" styleClass="glass-button" text="Save Entry" />
                    <Button fx:id="analyzeButton" styleClass="glass-button, ai-highlight" text="AI Analyze" />
                </HBox>
                
                <!-- JOURNAL EDITOR -->
                <VBox styleClass="journal-editor-container" VBox.vgrow="ALWAYS">
                    <Label text="What's on your mind today?" styleClass="caption-text" />
                    <TextArea fx:id="journalEditor" 
                             styleClass="journal-editor" 
                             promptText="Dear diary..." 
                             wrapText="true" 
                             VBox.vgrow="ALWAYS" />
                </VBox>
                
                <!-- SENTIMENT ANALYSIS RESULT -->
                <HBox fx:id="sentimentContainer" alignment="CENTER_LEFT" spacing="15" visible="false" styleClass="ai-highlight slide-in-up">
                    <Label text="AI Sentiment:" styleClass="caption-text" />
                    <Label fx:id="sentimentLabel" styleClass="ai-sentiment-badge" />
                    <Label fx:id="sentimentScore" styleClass="caption-text" />
                </HBox>
            </VBox>
        </StackPane>
    </center>
    
    <!-- RIGHT ANALYTICS PANE -->
    <right>
        <ScrollPane styleClass="glass-container" prefWidth="350" fitToWidth="true">
            <VBox spacing="20" styleClass="fade-in">
                <!-- MOOD OVERVIEW -->
                <VBox styleClass="analytics-container">
                    <Label text="Mood Overview" styleClass="chart-title" />
                    <PieChart fx:id="moodPieChart" styleClass="chart-pie" prefWidth="300" prefHeight="200" />
                </VBox>
                
                <!-- SENTIMENT TRENDS -->
                <VBox styleClass="analytics-container">
                    <Label text="Sentiment Trends" styleClass="chart-title" />
                    <AreaChart fx:id="sentimentAreaChart" styleClass="chart-area" prefWidth="300" prefHeight="200">
                        <xAxis>
                            <NumberAxis label="Days" styleClass="caption-text" />
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Sentiment" styleClass="caption-text" />
                        </yAxis>
                    </AreaChart>
                </VBox>
                
                <!-- RECENT ENTRIES -->
                <VBox styleClass="analytics-container">
                    <Label text="Recent Entries" styleClass="chart-title" />
                    <VBox fx:id="recentEntriesContainer" spacing="10">
                        <!-- Recent entries will be populated here -->
                    </VBox>
                </VBox>
                
                <!-- AI INSIGHTS -->
                <VBox styleClass="ai-highlight">
                    <Label text="AI Insights" styleClass="chart-title" />
                    <VBox spacing="10">
                        <Label fx:id="insightLabel" styleClass="body-text" wrapText="true" />
                        <Button fx:id="refreshInsightsButton" styleClass="glass-button" text="Refresh Insights" />
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </right>
    
</BorderPane>
