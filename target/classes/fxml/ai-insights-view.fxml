<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.NumberAxis?>

<ScrollPane fitToWidth="true" fitToHeight="true" styleClass="glass-container" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mindscribe.AIInsightsController">
    
    <VBox spacing="30" alignment="CENTER" maxWidth="1200" style="-fx-padding: 20;">
    
    <!-- Enhanced Header -->
    <VBox spacing="15" alignment="CENTER" styleClass="glass-surface">
        <Label text="🤖 AI Insights" style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #E2E8F0;" />
        <Label text="Your personal mental wellness companion" style="-fx-font-size: 18px; -fx-text-fill: #9CA3AF; -fx-font-style: italic;" />
        <Label fx:id="statusLabel" style="-fx-text-fill: #10B981; -fx-font-size: 14px;" />
    </VBox>
    
    <!-- Enhanced Vibe Card -->
    <VBox spacing="25" alignment="CENTER" styleClass="dashboard-card">
        <Label text="Your Weekly Emotional Vibe" styleClass="subtitle-text" />
        <Label fx:id="vibeLabel" text="📊 Analyzing..." 
               style="-fx-font-size: 56px; -fx-font-weight: 800; -fx-text-fill: #10B981;" />
        <HBox spacing="30" alignment="CENTER">
            <VBox spacing="8" alignment="CENTER" styleClass="stat-card">
                <Label fx:id="primarySentimentLabel" text="Loading..." 
                       style="-fx-font-size: 18px; -fx-text-fill: #10B981; -fx-font-weight: 600;" />
                <Label text="Primary Sentiment" styleClass="caption-text" />
            </VBox>
            <VBox spacing="8" alignment="CENTER" styleClass="stat-card">
                <Label fx:id="keyTriggerLabel" text="Loading..." 
                       style="-fx-font-size: 18px; -fx-text-fill: #F59E0B; -fx-font-weight: 600;" />
                <Label text="Key Trigger" styleClass="caption-text" />
            </VBox>
        </HBox>
    </VBox>
    
    <!-- Enhanced Visualization Panel -->
    <VBox spacing="30" maxWidth="1200">
        <Label text="📊 Your Emotional Landscape" styleClass="title-text" />
        
        <!-- Enhanced Mood Trend Chart -->
        <VBox spacing="20" styleClass="dashboard-card">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="📈" style="-fx-font-size: 28px; -fx-text-fill: #A5B4FC;" />
                <VBox spacing="5">
                    <Label text="Mood Trend Analysis (30 Days)" styleClass="subtitle-text" />
                    <Label text="Track your emotional patterns over time" styleClass="caption-text" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Sentiment Score: 0-1" styleClass="caption-text" />
            </HBox>
            <AreaChart fx:id="moodTrendChart" prefHeight="280" legendVisible="true" createSymbols="true">
                <xAxis>
                    <NumberAxis label="Day" tickLabelFill="#9CA3AF" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Mood Score" tickLabelFill="#9CA3AF" />
                </yAxis>
            </AreaChart>
        </VBox>
        
        <!-- Enhanced Word Cloud & Activity Correlation -->
        <HBox spacing="25" alignment="CENTER">
            <!-- Enhanced Word Cloud -->
            <VBox spacing="15" HBox.hgrow="ALWAYS" styleClass="dashboard-card">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="💭" style="-fx-font-size: 24px; -fx-text-fill: #A5B4FC;" />
                    <Label text="Common Themes" styleClass="subtitle-text" />
                </HBox>
                <VBox spacing="10" styleClass="glass-surface">
                    <Label fx:id="wordCloudLabel" text="Loading themes..." 
                           style="-fx-text-fill: #E2E8F0; -fx-wrap-text: true; -fx-line-spacing: 2;" 
                           styleClass="body-text" />
                </VBox>
            </VBox>
            
            <!-- Enhanced Activity Correlation -->
            <VBox spacing="15" HBox.hgrow="ALWAYS" styleClass="dashboard-card">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🎯" style="-fx-font-size: 24px; -fx-text-fill: #A5B4FC;" />
                    <Label text="Activity Correlation" styleClass="subtitle-text" />
                </HBox>
                <VBox spacing="10" styleClass="glass-surface">
                    <Label fx:id="activityCorrelationLabel" text="Loading correlation..." 
                           style="-fx-text-fill: #E2E8F0; -fx-wrap-text: true; -fx-line-spacing: 2;" 
                           styleClass="body-text" />
                </VBox>
            </VBox>
        </HBox>
    </VBox>
    
    <!-- Enhanced AI Insight Panel -->
    <VBox spacing="30" maxWidth="1200">
        <Label text="🧠 AI-Powered Insights" styleClass="title-text" />
        
        <!-- Enhanced Primary Analysis -->
        <VBox spacing="25" styleClass="dashboard-card">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="🔍" style="-fx-font-size: 28px; -fx-text-fill: #A5B4FC;" />
                <Label text="Personalized Analysis" styleClass="subtitle-text" />
            </HBox>
            
            <VBox spacing="20" styleClass="glass-surface">
                <HBox spacing="40" alignment="CENTER">
                    <VBox spacing="8" alignment="CENTER" styleClass="stat-card">
                        <Label fx:id="sentimentSummaryLabel" text="Loading..." 
                               style="-fx-font-size: 18px; -fx-text-fill: #10B981; -fx-font-weight: 600;" />
                        <Label text="Primary Sentiment" styleClass="caption-text" />
                    </VBox>
                    <VBox spacing="8" alignment="CENTER" styleClass="stat-card">
                        <Label fx:id="triggerSummaryLabel" text="Loading..." 
                               style="-fx-font-size: 18px; -fx-text-fill: #F59E0B; -fx-font-weight: 600;" />
                        <Label text="Key Trigger" styleClass="caption-text" />
                    </VBox>
                </HBox>
                
                <!-- Enhanced Insight Text -->
                <VBox spacing="15">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="💡" style="-fx-font-size: 20px; -fx-text-fill: #A5B4FC;" />
                        <Label text="Your Personal Insight" styleClass="subtitle-text" />
                    </HBox>
                    <VBox spacing="10" styleClass="glass-surface">
                        <Label fx:id="insightLabel" text="Analyzing your patterns..." 
                               style="-fx-font-size: 16px; -fx-text-fill: #E2E8F0; -fx-wrap-text: true; -fx-line-spacing: 3;" 
                               styleClass="body-text" />
                    </VBox>
                </VBox>
            </VBox>
        </VBox>
        
        <!-- Enhanced Focus for Tomorrow -->
        <VBox spacing="20" styleClass="dashboard-card">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="🎯" style="-fx-font-size: 28px; -fx-text-fill: #10B981;" />
                <Label text="Tomorrow's Focus" styleClass="subtitle-text" />
            </HBox>
            <VBox spacing="15" style="-fx-background-color: rgba(16, 185, 129, 0.1); -fx-background-radius: 15px; -fx-padding: 25px; -fx-border-color: #10B981; -fx-border-radius: 15px;">
                <Label fx:id="focusForTomorrowLabel" text="Loading your personalized focus..." 
                       style="-fx-font-size: 16px; -fx-text-fill: #E2E8F0; -fx-wrap-text: true; -fx-line-spacing: 3;" 
                       styleClass="body-text" />
            </VBox>
        </VBox>
    </VBox>
    
    <!-- Enhanced Action Section -->
    <VBox spacing="25" styleClass="dashboard-card">
        <Label text="🚀 Actions &amp; Export" styleClass="subtitle-text" />
        <HBox spacing="25" alignment="CENTER">
            <Button fx:id="refreshInsightsButton" text="🔄 Refresh Insights" 
                    styleClass="glass-button" prefWidth="180" prefHeight="55" />
            <Button fx:id="exportReportButton" text="📊 Export Report" 
                    styleClass="glass-button" prefWidth="180" prefHeight="55" />
            <Button fx:id="backButton" text="🏠 Back Home" 
                    styleClass="glass-button, primary-button" prefWidth="180" prefHeight="55" />
        </HBox>
        <VBox spacing="15" alignment="CENTER">
            <Label text="💡 How to Use These Insights" styleClass="subtitle-text" />
            <VBox spacing="8" alignment="CENTER">
                <Label text="• Review your insights weekly to track emotional patterns" styleClass="body-text" />
                <Label text="• Use tomorrow's focus to guide your daily mindfulness practice" styleClass="body-text" />
                <Label text="• Share insights with a therapist or trusted friend for support" styleClass="body-text" />
            </VBox>
        </VBox>
    </VBox>
    
    </VBox>
</ScrollPane>
