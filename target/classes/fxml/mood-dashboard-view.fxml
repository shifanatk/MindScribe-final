<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.ScrollPane?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.NumberAxis?>

<ScrollPane fitToWidth="true" fitToHeight="true" styleClass="glass-container" 
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.mindscribe.MoodDashboardController">
    
    <VBox spacing="25" alignment="CENTER" maxWidth="1000">
    
    <!-- Header -->
    <VBox spacing="10" alignment="CENTER">
        <Label text="📊 Mood Dashboard" styleClass="title-text" />
        <Label text="Track your emotional patterns and trends" styleClass="caption-text" />
        <Label fx:id="dateRangeLabel" styleClass="body-text" />
    </VBox>
    
    <!-- Dashboard Content -->
    <VBox spacing="30" maxWidth="1000">
        <!-- Mood Distribution -->
        <VBox spacing="20" styleClass="dashboard-card">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="📊" style="-fx-font-size: 24px; -fx-text-fill: #A5B4FC;" />
                <VBox spacing="5">
                    <Label text="Mood Distribution" styleClass="subtitle-text" />
                    <Label text="Your emotional breakdown over time" styleClass="caption-text" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Last 30 days" styleClass="caption-text" />
            </HBox>
            <PieChart fx:id="moodPieChart" legendVisible="true" prefHeight="300" 
                     styleClass="chart-pie" legendSide="BOTTOM" />
        </VBox>
        
        <!-- Sentiment Trends -->
        <VBox spacing="20" styleClass="dashboard-card">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="📈" style="-fx-font-size: 24px; -fx-text-fill: #A5B4FC;" />
                <VBox spacing="5">
                    <Label text="Sentiment Trends" styleClass="subtitle-text" />
                    <Label text="Daily emotional patterns over the last week" styleClass="caption-text" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label text="7-day view" styleClass="caption-text" />
            </HBox>
            <AreaChart fx:id="sentimentAreaChart" prefHeight="280" legendVisible="true" 
                      styleClass="chart-area" createSymbols="true">
                <xAxis>
                    <NumberAxis label="Days" tickUnit="1" minorTickVisible="false" 
                               style="-fx-text-fill: #9CA3AF;" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Number of Entries" minorTickVisible="false" 
                               style="-fx-text-fill: #9CA3AF;" />
                </yAxis>
            </AreaChart>
        </VBox>
        
        <!-- Monthly Trends -->
        <VBox spacing="20" styleClass="dashboard-card">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="📅" style="-fx-font-size: 24px; -fx-text-fill: #A5B4FC;" />
                <VBox spacing="5">
                    <Label text="Monthly Overview" styleClass="subtitle-text" />
                    <Label text="Your emotional journey this month" styleClass="caption-text" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="currentMonthLabel" text="Current month" styleClass="caption-text" />
            </HBox>
            <HBox spacing="20" alignment="CENTER">
                <VBox spacing="12" alignment="CENTER" styleClass="stat-card">
                    <Label fx:id="monthEntriesLabel" text="0" styleClass="stat-number" />
                    <Label text="📝 Entries" styleClass="stat-label" />
                    <Label text="This month" styleClass="caption-text" />
                </VBox>
                <VBox spacing="12" alignment="CENTER" styleClass="stat-card">
                    <Label fx:id="monthAvgSentimentLabel" text="0.0" styleClass="stat-number" />
                    <Label text="💭 Avg Mood" styleClass="stat-label" />
                    <Label text="This month" styleClass="caption-text" />
                </VBox>
                <VBox spacing="12" alignment="CENTER" styleClass="stat-card">
                    <Label fx:id="weekTrendLabel" text="→" styleClass="stat-number" />
                    <Label text="📊 Week Trend" styleClass="stat-label" />
                    <Label text="vs last week" styleClass="caption-text" />
                </VBox>
                <VBox spacing="12" alignment="CENTER" styleClass="stat-card">
                    <Label fx:id="bestDayLabel" text="-" styleClass="stat-number" />
                    <Label text="⭐ Best Day" styleClass="stat-label" />
                    <Label text="Most positive" styleClass="caption-text" />
                </VBox>
            </HBox>
        </VBox>
        
        <!-- Statistics Cards -->
        <HBox spacing="25" alignment="CENTER">
            <VBox spacing="12" alignment="CENTER" styleClass="stat-card">
                <Label fx:id="totalEntriesLabel" text="0" styleClass="stat-number" />
                <Label text="📝 Total Entries" styleClass="stat-label" />
                <Label text="All time" styleClass="caption-text" />
            </VBox>
            <VBox spacing="12" alignment="CENTER" styleClass="stat-card">
                <Label fx:id="avgSentimentLabel" text="0.0" styleClass="stat-number" />
                <Label text="💭 Avg Sentiment" styleClass="stat-label" />
                <Label text="Overall mood" styleClass="caption-text" />
            </VBox>
            <VBox spacing="12" alignment="CENTER" styleClass="stat-card">
                <Label fx:id="dominantMoodLabel" text="-" styleClass="stat-number" />
                <Label text="😊 Dominant Mood" styleClass="stat-label" />
                <Label text="Most frequent" styleClass="caption-text" />
            </VBox>
        </HBox>
        
        <!-- Action Buttons -->
        <HBox spacing="20" alignment="CENTER">
            <Button fx:id="refreshButton" styleClass="glass-button" text="🔄 Refresh Data" prefWidth="150" prefHeight="50" />
            <Button fx:id="exportButton" styleClass="glass-button" text="📥 Export Report" prefWidth="150" prefHeight="50" />
            <Button fx:id="backButton" styleClass="glass-button" text="🏠 Back to Home" prefWidth="170" prefHeight="50" />
        </HBox>
        
        <!-- Status Message -->
        <VBox spacing="10" alignment="CENTER">
            <Label fx:id="statusLabel" styleClass="status-text" wrapText="true" />
            <Label text="💡 Tip: Write regularly to get more accurate insights" styleClass="caption-text" />
        </VBox>
    </VBox>
    
    </VBox>
</ScrollPane>
