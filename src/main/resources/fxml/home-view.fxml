<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane fx:id="mainPane" styleClass="main-border-pane" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mindscribe.HomeController">
    
    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="20">
            <!-- App Logo/Home -->
            <Button fx:id="homeButton" styleClass="sidebar-button, selected" text="🏠" />
            
            <!-- Journal Entries -->
            <Button fx:id="journalButton" styleClass="sidebar-button" text="📝" />
            
            <!-- Analytics -->
            <Button fx:id="analyticsButton" styleClass="sidebar-button" text="📊" />
            
            <!-- AI Insights -->
            <Button fx:id="aiButton" styleClass="sidebar-button" text="🤖" />
            
            <!-- Settings -->
            <Button fx:id="settingsButton" styleClass="sidebar-button" text="⚙️" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <!-- Logout Button -->
            <Button fx:id="logoutButton" styleClass="glass-button" text="🚪 Logout" prefWidth="60" prefHeight="40" />
        </VBox>
    </left>
    
    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="30" alignment="TOP_CENTER" styleClass="glass-container">
            <!-- HEADER -->
            <VBox spacing="15" alignment="CENTER">
                <Label fx:id="dateLabel" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #A5B4FC;" />
                <Button fx:id="writeJournalButton" styleClass="glass-button, primary-button" text="✍️ Write New Journal Entry" prefWidth="250" prefHeight="50" />
            </VBox>
            
            <!-- STATS CARDS -->
            <HBox spacing="25" alignment="CENTER">
                <VBox spacing="10" alignment="CENTER" styleClass="stat-card">
                    <Label text="📝" style="-fx-font-size: 32px;" />
                    <Label text="Total Entries" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #9CA3AF;" />
                    <Label fx:id="totalEntriesLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #E2E8F0;" />
                </VBox>
                <VBox spacing="10" alignment="CENTER" styleClass="stat-card">
                    <Label text="😊" style="-fx-font-size: 32px;" />
                    <Label text="Current Mood" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #9CA3AF;" />
                    <Label fx:id="currentMoodLabel" text="Neutral" style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #10B981;" />
                </VBox>
                <VBox spacing="10" alignment="CENTER" styleClass="stat-card">
                    <Label text="🔥" style="-fx-font-size: 32px;" />
                    <Label text="Day Streak" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #9CA3AF;" />
                    <Label fx:id="dayStreakLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #F59E0B;" />
                </VBox>
            </HBox>
            
            <!-- Quick Actions -->
            <VBox spacing="20" alignment="CENTER">
                <Label text="Quick Actions" style="-fx-font-size: 20px; -fx-font-weight: 600; -fx-text-fill: #E2E8F0;" />
                <HBox spacing="20" alignment="CENTER">
                    <Button fx:id="viewEntriesButton" styleClass="glass-button" text="📚 View Entries" prefWidth="180" prefHeight="45" />
                    <Button fx:id="analyticsButton" styleClass="glass-button" text="📊 Analytics" prefWidth="180" prefHeight="45" />
                    <Button fx:id="aiButton" styleClass="glass-button" text="🤖 AI Insights" prefWidth="180" prefHeight="45" />
                </HBox>
            </VBox>
        </VBox>
    </center>
    
</BorderPane>
